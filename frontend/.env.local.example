# ── Backend relay service ─────────────────────────────────────────────────────
# URL of the ShadowBridge backend (backend/src/server.ts). The frontend uses
# this for the relay REST API and WebSocket subscription.
NEXT_PUBLIC_BACKEND_URL=http://localhost:3001

# ── RPC endpoints ────────────────────────────────────────────────────────────
NEXT_PUBLIC_ETH_SEPOLIA_RPC=https://sepolia.infura.io/v3/YOUR_INFURA_KEY
NEXT_PUBLIC_BASE_SEPOLIA_RPC=https://sepolia.base.org
NEXT_PUBLIC_ARB_SEPOLIA_RPC=https://sepolia-rollup.arbitrum.io/rpc

# ── Deployed contract addresses ───────────────────────────────────────────────
